# Copy to .env and fill in. .env is gitignored — never commit real keys.
# Variable names below were read out of the genblaze adapter source, not guessed.

# --- Transcription: AssemblyAI -----------------------------------------------
# Free: $50 credits, no card. ~333 hrs on universal-2 ($0.15/hr) => effectively free.
# genblaze_assemblyai/provider.py:233  ->  os.getenv("ASSEMBLYAI_API_KEY")
ASSEMBLYAI_API_KEY=

# --- TTS primary: ElevenLabs -------------------------------------------------
# Starter $6/mo. Needed for Instant Voice Cloning (free-tier cloning is ambiguous
# in their docs — it's a $6 question, just pay it).
# Read by the vendor SDK; genblaze passes api_key through only if set explicitly.
ELEVENLABS_API_KEY=

# --- TTS backup: LMNT --------------------------------------------------------
# Free tier, cloning included even on free. This is the ONLY viable voice-preserving
# backup — OpenAI has no self-serve cloning, Hume gates it above Enterprise.
LMNT_API_KEY=

# --- TTS last resort: OpenAI (optional) --------------------------------------
# Can say the words but NOT in the cloned voice. Third rung only, for languages
# where LMNT also fails. ~$0.27 for the whole demo.
OPENAI_API_KEY=

# --- Storage: Backblaze B2 ---------------------------------------------------
# 10 GB free. B2_REGION MUST be set explicitly — S3StorageBackend.for_backblaze()
# auto-detects region from a 301 redirect, but us-east-005 returns 403 instead,
# so auto-detection silently fails there.
B2_KEY_ID=
B2_APP_KEY=
B2_BUCKET=
B2_REGION=us-east-005
